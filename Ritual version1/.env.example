# Supabase (public — safe to expose in browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Calendar OAuth (public — client ID only)
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# ── Supabase Edge Function secrets ────────────────────────────────────────
# Set these with the Supabase CLI, NOT in this file:
#
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#
# These are never exposed to the browser or to Vercel.
# ANTHROPIC_API_KEY is read only by the ai-proxy edge function at runtime.
